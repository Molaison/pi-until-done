# Normalize all text to LF in the repo (eol=lf) so checkouts on Windows
# don't pick up CRLF line endings that break biome format/lint and other
# line-ending-sensitive tooling.

* text=auto eol=lf

# Source code — always LF.
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.lock text eol=lf

# Binary blobs — never line-ending-mangled.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tgz binary
*.lockb binary
